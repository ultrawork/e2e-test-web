# URL бэкенд API (Next.js публичная переменная окружения)
# Для локального запуска укажи адрес бэкенда (по умолчанию порт 3000)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Примеры для разных окружений:
# NEXT_PUBLIC_API_URL=http://localhost:3000/api   # локальный бэкенд
# NEXT_PUBLIC_API_URL=https://api.example.com/api # продакшн
