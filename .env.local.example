# URL backend API (без trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Как получить dev-токен:
# 1. Запустите backend (JWT_ENABLED не обязателен для dev-bypass)
# 2. Если JWT_ENABLED=true, выполните:
#    curl -X POST http://localhost:3000/api/auth/dev-token
# 3. Скопируйте значение поля "token"
# 4. В консоли браузера выполните:
#    localStorage.setItem('token', 'ВСТАВЬТЕ_ТОКЕН_СЮДА')
